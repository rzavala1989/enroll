{
  "name": "enroll",
  "version": "0.1.0",
  "private": true,
  "description": "Course registration system for the UCR Senior Developer interview prep",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "db:migrate": "pnpm --filter api prisma migrate dev",
    "db:studio": "pnpm --filter api prisma studio",
    "db:generate": "pnpm --filter api prisma generate",
    "build:shared": "pnpm --filter @enroll/shared build"
  },
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  },
  "dependencies": {
    "@tsoa/runtime": "^7.0.0-alpha.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34"
  }
}
