DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
JWT_ACCESS_SECRET="change-me" // gen with `openssl rand -hex 32`
JWT_REFRESH_SECRET="change-me-too" // gen with `openssl rand -hex 32`
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"
PORT=3000

# Phase 5 audit log destination (Mongo).
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/?appName=enroll"
MONGODB_DB="enroll_audit"

# Phase 6 waitlist promotion queue (BullMQ / Redis).
REDIS_URL="redis://localhost:6379"
