datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  ADVISOR
  ADMIN
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  WAITLISTED
  COMPLETED
}

enum Season {
  FALL
  WINTER
  SPRING
  SUMMER
}

model User {
  id           String @id @default(uuid()) @db.Uuid
  email        String @unique
  passwordHash String
  firstName    String
  lastName     String
  roles        Role[] @default([STUDENT])

  // self-referential: a user (advisee) has one advisor (also a User)
  advisorId String? @db.Uuid
  advisor   User?   @relation("AdvisorAdvisee", fields: [advisorId], references: [id])
  advisees  User[]  @relation("AdvisorAdvisee")

  enrollments Enrollment[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  RefreshToken RefreshToken[]

  @@index([advisorId])
}

model RefreshToken {
  id           String    @id @default(uuid())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String    @db.Uuid
  tokenHash    String    @unique
  family       String
  createdAt    DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?   @db.Uuid

  @@index([family])
  @@index([userId])
}

model Term {
  id                 String   @id @default(uuid()) @db.Uuid
  season             Season
  year               Int
  startDate          DateTime
  endDate            DateTime
  registrationOpens  DateTime
  registrationCloses DateTime

  sections Section[]

  @@unique([season, year])
}

model Course {
  id          String  @id @default(uuid()) @db.Uuid
  code        String  @unique // e.g. "CS101"
  title       String // e.g. "Intro to Computer Science"
  description String?
  credits     Int

  sections Section[]

  // Generated FTS column maintained by Postgres (see migration
  // 20260428070000_add_course_fts: GENERATED ALWAYS AS ... STORED).
  // Prisma cannot model generated columns, so every `migrate dev` that
  // diffs Course will emit two bogus lines:
  //   DROP INDEX "Course_searchVector_idx";
  //   ALTER TABLE "Course" ALTER COLUMN "searchVector" DROP DEFAULT;
  // The DROP DEFAULT will fail at apply time (Postgres needs DROP
  // EXPRESSION on generated columns). Workflow: run `migrate dev
  // --create-only`, delete those two lines from the generated SQL,
  // then `migrate deploy`. Unsupported types are excluded from the
  // generated client, so raw queries reach this column via $queryRaw.
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id            String @id @default(uuid()) @db.Uuid
  sectionNumber String // e.g. "001"

  courseId String @db.Uuid
  course   Course @relation(fields: [courseId], references: [id])

  termId String @db.Uuid
  term   Term   @relation(fields: [termId], references: [id])

  instructorName String
  meetingPattern String // e.g. "MWF 9:00-9:50"
  room           String

  capacity      Int
  enrolledCount Int @default(0) // denormalized for performance

  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, sectionNumber, termId])
  @@index([termId])
}

model Enrollment {
  id String @id @default(uuid()) @db.Uuid

  studentId String @db.Uuid
  student   User   @relation(fields: [studentId], references: [id])

  sectionId String  @db.Uuid
  section   Section @relation(fields: [sectionId], references: [id])

  status EnrollmentStatus @default(ENROLLED)

  /// Sparse per-section waitlist sequence value; non-null only while status = WAITLISTED.
  /// Never renumbered, just freed (set null) on promotion or drop. Display rank is computed on read.
  waitlistPosition Int?

  enrolledAt  DateTime  @default(now())
  droppedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([sectionId])
  @@index([status])
  @@index([sectionId, waitlistPosition])
}

// Phase 5 audit outbox. Rows are written inside the same Postgres
// transaction as the business mutation, then drained to Mongo by the
// AuditOutboxWorker. Index on (drainedAt, id) supports the worker's
// "oldest undrained first" scan with `WHERE drainedAt IS NULL`.
model AuditOutbox {
  id BigInt @id @default(autoincrement())

  action         String
  actorUserId    String? @db.Uuid
  actorIp        String?
  actorUserAgent String?

  targetType String
  targetId   String

  payload Json

  createdAt DateTime  @default(now())
  drainedAt DateTime?

  @@index([drainedAt, id])
}
