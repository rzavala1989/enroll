datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  STUDENT
  ADVISOR
  ADMIN
}

enum EnrollmentStatus {
  ENROLLED
  DROPPED
  WAITLISTED
  COMPLETED
}

enum Season {
  FALL
  WINTER
  SPRING
  SUMMER
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  passwordHash  String
  firstName     String
  lastName      String
  roles         Role[]   @default([STUDENT])

  // self-referential: a user (advisee) has one advisor (also a User)
  advisorId     String?  @db.Uuid
  advisor       User?    @relation("AdvisorAdvisee", fields: [advisorId], references: [id])
  advisees      User[]   @relation("AdvisorAdvisee")

  enrollments   Enrollment[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([advisorId])
}

model Term {
  id                  String   @id @default(uuid()) @db.Uuid
  season              Season
  year                Int
  startDate           DateTime
  endDate             DateTime
  registrationOpens   DateTime
  registrationCloses  DateTime

  sections            Section[]

  @@unique([season, year])
}

model Course {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique  // e.g. "CS101"
  title       String              // e.g. "Intro to Computer Science"
  description String?
  credits     Int

  sections    Section[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Section {
  id              String   @id @default(uuid()) @db.Uuid
  sectionNumber   String              // e.g. "001"

  courseId        String   @db.Uuid
  course          Course   @relation(fields: [courseId], references: [id])

  termId          String   @db.Uuid
  term            Term     @relation(fields: [termId], references: [id])

  instructorName  String
  meetingPattern  String              // e.g. "MWF 9:00-9:50"
  room            String

  capacity        Int
  enrolledCount   Int      @default(0)  // denormalized for performance

  enrollments     Enrollment[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([courseId, sectionNumber, termId])
  @@index([termId])
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid

  studentId   String           @db.Uuid
  student     User             @relation(fields: [studentId], references: [id])

  sectionId   String           @db.Uuid
  section     Section          @relation(fields: [sectionId], references: [id])

  status      EnrollmentStatus @default(ENROLLED)

  enrolledAt  DateTime         @default(now())
  droppedAt   DateTime?
  completedAt DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  // TODO: a student can only have one ACTIVE enrollment per section, but they
  // could drop and re-enroll. Enforce via partial unique index in a follow-up
  // migration (raw SQL: UNIQUE (studentId, sectionId) WHERE status = 'ENROLLED')
  // plus an application-level check before insert.
  @@index([studentId])
  @@index([sectionId])
  @@index([status])
}
